# GenRefの実装
gmallocと、gfreeを実装する。
値型でないものは、基本的にサイズが変わらないstructはheader, datasを持つ。
# ただ、これはかなり重そうなので後々でもいいかも

struct GenRef[T]:
    slot_ptr: *Slot[T]
    generation: u64

struct Pool[T]:
    chunks: Vec[Chunk[T]]
    free_list: *Slot[T]

struct Slot[T]:
    # header
    generation: u64
    alive: bool
    next_free: *Slot[T]
    # data
    MaybeUninit[T]

struct Chunk[Enemy]
    slots: [Slot[Enemy]; 1024]

# StringやVecなどの可変長は例外
